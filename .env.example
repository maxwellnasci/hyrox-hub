# Supabase (client — safe to expose in browser bundle via VITE_ prefix)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Server-only (Cloudflare Workers secrets / .dev.vars — NEVER commit real values)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
COACH_INVITE_CODE=your-coach-invite-code
